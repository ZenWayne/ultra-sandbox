#!/bin/bash
# Claude Code - auto-maps host commands listed in SANDBOX_MAP_PROCESSES
#
# Environment variables:
#   SANDBOX_MAP_PROCESSES   space-separated commands to proxy (e.g. "podman adb")
#   SANDBOX_DIR             shim/socket dir (default: ~/.ultra_sandbox)

set -e

replace_proxy() {
    local proxy="$1"
    echo "${proxy//127.0.0.1:10809/host.docker.internal:10809}"
}

WORK_DIR=$(pwd)
export SANDBOX_DIR="${SANDBOX_DIR:-$WORK_DIR/.ultra_sandbox}"

# Cleanup function - remove sandbox dir on exit
cleanup() {
    rm -rf "$SANDBOX_DIR"
}
trap cleanup EXIT

# --- Sandbox setup (only if SANDBOX_MAP_PROCESSES is set) -------------------
if [ -n "$SANDBOX_MAP_PROCESSES" ]; then
    if ! command -v sandbox &>/dev/null; then
        echo "Error: 'sandbox' not found in PATH. Install it to ~/.local/bin/sandbox first."
        exit 1
    fi

    mkdir -p "$SANDBOX_DIR/bin"

    if [ ! -S "$SANDBOX_DIR/daemon.sock" ]; then
        echo "Starting sandbox daemon..."
        sandbox daemon &
        sleep 0.3
    fi

    for cmd in $SANDBOX_MAP_PROCESSES; do
        sandbox map "$cmd"
    done

    echo "=== sandbox mapped: $SANDBOX_MAP_PROCESSES ==="
fi

# --- Launch container --------------------------------------------------------
WORK_DIR=$(pwd)
VOLUME_NAME="claude-yolo-$(echo "$WORK_DIR" | sed 's/[^a-zA-Z0-9]/_/g' | tr '[:upper:]' '[:lower:]')"
VOLUME_ARGS=(-v "$WORK_DIR:$WORK_DIR")

if [ -d ".venv" ]; then
    VOLUME_ARGS+=(-v "${VOLUME_NAME}_venv:$WORK_DIR/.venv")
fi

SANDBOX_VOLUME_ARGS=()
SANDBOX_ENV_ARGS=()
if [ -n "$SANDBOX_MAP_PROCESSES" ]; then
    SANDBOX_VOLUME_ARGS=(
        -v "$SANDBOX_DIR:/ultra_sandbox"
        -v "$HOME/.local/bin/sandbox:/usr/local/bin/sandbox:ro"
    )
    SANDBOX_ENV_ARGS=(
        -e SANDBOX_DIR="/ultra_sandbox"
        -e PATH="/ultra_sandbox/bin:/home/$USER/.local/bin:/usr/local/bin:/usr/bin:/bin"
    )
else
    SANDBOX_ENV_ARGS=(
        -e PATH="/home/$USER/.local/bin:/usr/local/bin:/usr/bin:/bin"
    )
fi

podman run -it --rm \
    --userns=keep-id \
    --network=host \
    "${VOLUME_ARGS[@]}" \
    "${SANDBOX_VOLUME_ARGS[@]}" \
    -v "$HOME/.claude":"/home/$USER/.claude" \
    -v "$HOME/.claude.json":"/home/$USER/.claude.json" \
    -e ANTHROPIC_BASE_URL="$ANTHROPIC_BASE_URL" \
    -e ANTHROPIC_API_KEY="$ANTHROPIC_API_KEY" \
    -e DISABLE_AUTOUPDATER=1 \
    -e LANG="$LANG" \
    -e http_proxy="$(replace_proxy "$http_proxy")" \
    -e https_proxy="$(replace_proxy "$https_proxy")" \
    -e HTTP_PROXY="$(replace_proxy "$HTTP_PROXY")" \
    -e HTTPS_PROXY="$(replace_proxy "$HTTPS_PROXY")" \
    -e NO_PROXY="$NO_PROXY" \
    -e no_proxy="$no_proxy" \
    -e TERM=xterm-256color \
    -e HOME="/home/$USER" \
    "${SANDBOX_ENV_ARGS[@]}" \
    -w "$WORK_DIR" \
    --entrypoint /home/$USER/.local/bin/claude \
    localhost/claude_code_base:latest \
    --dangerously-skip-permissions "$@"
